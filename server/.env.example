APP_NAME=Nexora
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

MYSQL_DATABASE=nexora
MYSQL_USER=nexora
MYSQL_PASSWORD=nexora123
MYSQL_ROOT_PASSWORD=root123

DB_HOST=mysql
DB_PORT=3306
DB_NAME=nexora
DB_USER=nexora
DB_PASSWORD=nexora123

DATABASE_URL=mysql+pymysql://nexora:nexora123@mysql:3306/nexora

SECRET_KEY=change-this-to-a-long-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=720

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

CORS_ALLOW_ORIGINS=*

# Upload storage root. In Docker compose this is overridden to /app/uploads.
UPLOADS_DIR=uploads
DEFAULT_MAX_UPLOAD_MB=10
